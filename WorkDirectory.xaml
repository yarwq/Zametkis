<Window x:Class="Zametkis.WorkDirectory"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Zametkis"
        mc:Ignorable="d"
        Title="Zametkis" Height="800" Width="1100"
        WindowState="Maximized"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="Segoe UI">
    <Grid Name="Grid1">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="16,12">
                <Button x:Name="PaintToolButton" Content="Рисование"
                        Click="AddPaint" ClickMode="Press"
                        Style="{StaticResource ToolButtonStyle}"/>
                <Button x:Name="TextToolButton" Content="Текст"
                        Click="AddText" ClickMode="Press"
                        Style="{StaticResource ToolButtonStyle}"/>
                <Button x:Name="PhotoToolButton" Content="Фото"
                        Click="AddPhoto" ClickMode="Press"
                        Style="{StaticResource ToolButtonStyle}"/>
                <Border Width="1" Margin="4,4" Background="{StaticResource BorderBrush}"/>
                <Button x:Name="SaveButton" Content="Сохранить"
                        Click="SaveZametki" ClickMode="Press"
                        Style="{StaticResource ToolButtonStyle}"/>
            </StackPanel>
        </Border>
        <Canvas Name="paintSurface" Grid.Row="1"
                MouseMove="DrawME" MouseDown="PaintME"
                MouseLeftButtonDown="WorkWithTool" MouseWheel="ZoomInAndOut"
                MouseUp="StopMoving">
            <Canvas.Background>
                <DrawingBrush TileMode="Tile" Viewport="0,0,24,24" ViewportUnits="Absolute" Stretch="None">
                    <DrawingBrush.Drawing>
                        <DrawingGroup>
                            <GeometryDrawing Brush="#FFFBFBFD">
                                <GeometryDrawing.Geometry>
                                    <RectangleGeometry Rect="0,0,24,24"/>
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                            <GeometryDrawing Brush="#FFD3D3DE">
                                <GeometryDrawing.Geometry>
                                    <EllipseGeometry Center="12,12" RadiusX="1.3" RadiusY="1.3"/>
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                        </DrawingGroup>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Canvas.Background>
        </Canvas>
    </Grid>
</Window>