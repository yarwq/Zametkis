<Window  x:Class="Zametkis.MainWindow"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:local="clr-namespace:Zametkis"
                   mc:Ignorable="d"
                   Title="Zametkis" Height="500" Width="500"
                   Background="{StaticResource BackgroundBrush}"
                   FontFamily="Segoe UI"
                   WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="280">
            <TextBlock Text="Zametkis" FontSize="32" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Бесконечная доска для заметок" FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,6,0,32"
                       HorizontalAlignment="Center"/>

            <Button x:Name="btn1" Content="Создать новую заметку"
                    Click="CreateNewZametki" ClickMode="Press"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Margin="0,0,0,12"/>

            <Button x:Name="btn2" Content="Открыть заметку"
                    Click="ReadZametki" ClickMode="Press"
                    Style="{StaticResource SecondaryButtonStyle}"
                    HorizontalAlignment="Stretch"/>
        </StackPanel>
    </Grid>
</Window>
